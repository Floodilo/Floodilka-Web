# ─── Floodilka Development Environment ─────────────────────────────────────

# Public endpoints
FLOODILKA_API_PUBLIC_ENDPOINT=http://localhost:3001
FLOODILKA_APP_ENDPOINT=http://localhost:8088
FLOODILKA_GATEWAY_ENDPOINT=ws://localhost:8080
FLOODILKA_MEDIA_ENDPOINT=http://localhost:3002
FLOODILKA_CDN_ENDPOINT=http://localhost:9000/floodilka-uploads
FLOODILKA_MARKETING_ENDPOINT=http://localhost:8088
FLOODILKA_ADMIN_ENDPOINT=http://localhost:8088
FLOODILKA_INVITE_ENDPOINT=http://localhost:8088/invite
FLOODILKA_GIFT_ENDPOINT=http://localhost:8088/gift
FLOODILKA_PATH_MARKETING=/marketing
FLOODILKA_PATH_ADMIN=/admin

# Cassandra / ScyllaDB
CASSANDRA_HOSTS=cassandra
CASSANDRA_KEYSPACE=floodilka
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra

# Valkey (HA Sentinel mode — also used in dev via valkey-sentinel sidecar)
VALKEY_SENTINELS=valkey-sentinel:26379
VALKEY_MASTER_NAME=floodilka-master

# Gateway RPC
GATEWAY_RPC_HOST=gateway
GATEWAY_RPC_PORT=8081
GATEWAY_RPC_SECRET=dev_rpc_secret_change_me

# Media Proxy
MEDIA_PROXY_SECRET_KEY=dev_media_proxy_secret_change_me
MEDIA_PROXY_ENDPOINT=http://media:3002

# S3 / MinIO
AWS_S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET_CDN=floodilka-uploads
AWS_S3_BUCKET_UPLOADS=floodilka-uploads
AWS_S3_BUCKET_REPORTS=floodilka-uploads
AWS_S3_BUCKET_HARVESTS=floodilka-uploads
AWS_S3_BUCKET_DOWNLOADS=floodilka-uploads

# Captcha (disabled in dev)
CAPTCHA_PROVIDER=none

# MeiliSearch
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=masterKey

# LiveKit
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret

# Auth
SUDO_MODE_SECRET=dev_sudo_secret_change_me
JWT_SECRET=dev_jwt_secret_change_me

# Sentry (disabled in dev)
# SENTRY_DSN=

# Cloudflare Tunnel (optional)
# CLOUDFLARE_TUNNEL_TOKEN=

# CloudPayments (optional)
# CLOUDPAYMENTS_ENABLED=true
# CLOUDPAYMENTS_PUBLIC_ID=
# CLOUDPAYMENTS_API_SECRET=
# CLOUDPAYMENTS_PRICE_MONTHLY_RUB=29900
# CLOUDPAYMENTS_PRICE_YEARLY_RUB=249900
# CLOUDPAYMENTS_PRICE_GIFT_1_MONTH_RUB=29900
# CLOUDPAYMENTS_PRICE_GIFT_1_YEAR_RUB=249900

# SendGrid (optional)
# SENDGRID_API_KEY=

# Twilio (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# MaxMind GeoIP (optional)
# MAXMIND_LICENSE_KEY=
